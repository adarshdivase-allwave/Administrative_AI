{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["./shared/*"],
      "@functions/*": ["./amplify/functions/*"],
      "@data/*": ["./amplify/data/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "amplify/**/*.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".amplify"]
}
