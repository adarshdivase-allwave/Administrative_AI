# ==========================================================================
# AV Inventory Platform — Environment variables (example)
# Copy to .env.dev / .env.staging / .env.prod and fill in real values.
# NEVER commit the filled copies.
# ==========================================================================

# --- AWS context ---
AWS_REGION=ap-south-1                              # Mumbai for India ops
AWS_PROFILE=av-inventory-dev
AMPLIFY_APP_ID=

# --- Environment name (drives table naming, schedule identifiers) ---
APP_ENV=dev                                        # dev | staging | prod

# --- Company identity (also seeded into SystemSettings table) ---
COMPANY_NAME=""
COMPANY_GSTIN=""                                   # 15-char, validated
COMPANY_STATE_CODE=""                              # first 2 digits of GSTIN
COMPANY_ADDRESS=""
COMPANY_OPS_EMAIL=""
COMPANY_LOGO_PUBLIC_URL=""                         # S3 public bucket URL

# --- India FY + numbering defaults ---
FY_INVOICE_PREFIX=INV
FY_DC_PREFIX=DC
FY_GRN_PREFIX=GRN
FY_PO_PREFIX=PO
EWAY_BILL_THRESHOLD_INR=50000
PO_APPROVAL_THRESHOLD_INR=50000

# --- MSME / MSMED Act 2006 ---
MSME_ENABLED=true
MSME_UDYAM_REGISTRATION=""
MSME_ENTERPRISE_CLASS=MICRO                        # MICRO | SMALL | MEDIUM
MSME_REQUIRE_ADMIN_APPROVAL=false
MSME_AUTO_TRIGGER_DAYS=45

# --- Session / security ---
COGNITO_IDLE_SESSION_TTL_SECONDS=1800
COGNITO_REQUIRE_MFA_FOR_ADMIN=false

# --- SES (domain must be verified with DKIM + SPF before go-live) ---
SES_FROM_DOMAIN=""                                 # e.g. inventory.yourco.in
SES_FROM_EMAIL=no-reply@inventory.yourco.in
SES_REPLY_TO=""
SES_CONFIGURATION_SET=av-inventory-prod

# --- External API keys (actually stored in Secrets Manager — these names
#     are the *secret IDs*, not the key values themselves) ---
SECRET_ID_GEMINI=av-inventory/gemini-api-key
SECRET_ID_EXCHANGE_RATE=av-inventory/exchangerate-api-key

# --- OpenSearch Serverless (set after collection is created) ---
OPENSEARCH_COLLECTION_ENDPOINT=
OPENSEARCH_HSN_INDEX=hsn-india-gst
OPENSEARCH_SEARCH_INDEX=av-inventory-search

# --- Chatbot rate limit ---
CHATBOT_RATE_LIMIT_PER_MIN=10
