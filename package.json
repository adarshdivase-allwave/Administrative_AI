{
  "name": "av-inventory-backend",
  "version": "5.0.0",
  "description": "AV Integration Inventory & Operations Management Platform — India GST / MSMED / Tally / e-Way Bill compliant. Amplify Gen 2 backend.",
  "private": true,
  "type": "module",
  "scripts": {
    "sandbox": "ampx sandbox",
    "sandbox:dev": "ampx sandbox --identifier dev",
    "sandbox:staging": "ampx sandbox --identifier staging",
    "deploy:prod": "ampx pipeline-deploy --branch prod --app-id $AMPLIFY_APP_ID",
    "build:ses-templates": "tsx scripts/build-ses-templates.ts",
    "seed:hsn": "tsx scripts/seed-hsn.ts",
    "seed:samples": "tsx scripts/seed-samples.ts",
    "verify:pitr": "tsx scripts/verify-pitr.ts",
    "test:fy-rollover": "tsx scripts/test-fy-rollover.ts",
    "test": "tsx --test --test-reporter=spec \"tests/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"tests/**/*.test.ts\"",
    "test:coverage": "tsx --test --experimental-test-coverage \"tests/**/*.test.ts\"",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@aws-amplify/backend": "^1.16.0",
    "@aws-amplify/backend-cli": "^1.7.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.699.0",
    "@aws-sdk/client-dynamodb": "^3.699.0",
    "@aws-sdk/client-eventbridge": "^3.699.0",
    "@aws-sdk/client-opensearchserverless": "^3.699.0",
    "@aws-sdk/client-s3": "^3.699.0",
    "@aws-sdk/client-scheduler": "^3.699.0",
    "@aws-sdk/client-secrets-manager": "^3.699.0",
    "@aws-sdk/client-ses": "^3.699.0",
    "@aws-sdk/client-sesv2": "^3.699.0",
    "@aws-sdk/client-sns": "^3.699.0",
    "@aws-sdk/lib-dynamodb": "^3.699.0",
    "@aws-sdk/s3-request-presigner": "^3.699.0",
    "@aws-sdk/util-dynamodb": "^3.699.0",
    "@opensearch-project/opensearch": "^2.12.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "fast-xml-parser": "^4.5.1",
    "nodemailer": "^6.9.16",
    "uuid": "^11.0.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
