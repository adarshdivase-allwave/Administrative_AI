# Frontend env vars — copy to .env.local and fill in.
# After `ampx sandbox` runs, these values appear in amplify_outputs.json;
# the Amplify client reads that file directly so these are just overrides.

VITE_APP_ENV=dev

# Optional: if you want to hit a non-default AppSync endpoint
# VITE_APPSYNC_URL=
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_USER_POOL_CLIENT_ID=
# VITE_STORAGE_PRIVATE_BUCKET=
# VITE_STORAGE_EMAIL_ASSETS_BUCKET=

# Company identity (shown in auth page, emails)
VITE_COMPANY_NAME="AV Inventory"
VITE_COMPANY_LOGO_URL=

# Chatbot widget toggle
VITE_CHATBOT_ENABLED=true

# Session timeout warning: shown N minutes before Cognito IdleSessionTTL
VITE_SESSION_WARNING_MINUTES=5
